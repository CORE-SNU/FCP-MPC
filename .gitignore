# editor / python junk
**/__pycache__
**/.vscode
**/.DS_Store

# bulky data & media (regenerable, not needed in git)
**/*.mp4
**/*.avi
**/*.mov
**/*.csv
**/*.xlsx
**/*.pkl
**/*.npy
**/*.npz
**/*.txt
**/*.json
**/*.log
**/*.zip
**/metric_3d
**/metric_2d

# Figures, bibliography and class files are regenerable / managed elsewhere.
**/*.png
**/*.bib
**/*.cls

# The paper (T_RO2026) lives on Overleaf, not in this code repo.
T_RO2026/

# Scene homographies are small and needed to render the spatial-uncertainty
# overlay; track them (videos stay ignored -- re-fetch via planar/assets/download_videos.sh).
!planar/assets/homographies/
!planar/assets/homographies/*.txt

# Raw SDD dataset (downloaded, large) -- not tracked; re-fetch per docs/HANDOFF.md.
SDD/
sdd_data/

# ...but DO track the SDD analysis OUTPUTS (figures / per-cell result data) produced
# by analyze_spatial_uncertainty_ext.py at the repo root.
!sdd_*_overlay.png
!sdd_*_diag.png
!sdd_*_cells.npz
